        "rcade": "^0.0.48",
        "typescript": "^5.8.0",
        "typescript-eslint": "^8.59.3",
        "vite": "^7.2.4",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "@rcade/plugin-input-classic": "^0.2.1",
        "@rcade/plugin-input-spinners": "^0.2.3",
        "p5": "^1.11.3"
    }
