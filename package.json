{
    "name": "chronostroid",
    "private": false,
    "version": "1.0.0",
    "description": "PvP Asteroid + time travel",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"vite --port 5173 --strictPort\" \"rcade dev http://localhost:5173\"",
